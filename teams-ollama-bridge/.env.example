APP_ENV=development
LOG_LEVEL=INFO
LOG_MESSAGE_CONTENT=false

TEAMS_LLM_ROOT=C:\Users\<BENUTZER>\OneDrive - <ORGANISATION>\TeamsLLM

INPUT_DIR=
OUTPUT_DIR=
PROCESSED_INPUT_DIR=
FAILED_INPUT_DIR=

PROCESSOR_MODE=mock

POLL_INTERVAL_SECONDS=2
FILE_STABLE_SECONDS=2
MAX_PROCESS_RETRIES=3
RETRY_DELAY_SECONDS=5
STALE_PROCESSING_MINUTES=10

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_KEEP_ALIVE=10m
OLLAMA_TEMPERATURE=0.2

LLM_SYSTEM_PROMPT=Du bist ein hilfreicher interner Assistent in Microsoft Teams. Antworte präzise, sachlich und auf Deutsch. Gib nur die eigentliche Antwort aus.
LLM_MAX_INPUT_CHARACTERS=12000
LLM_MAX_OUTPUT_CHARACTERS=20000

DATABASE_PATH=data\state.db
LOCK_FILE_PATH=data\worker.lock

LOG_FILE_PATH=logs\teams-ollama-bridge.log
LOG_MAX_BYTES=5000000
LOG_BACKUP_COUNT=5

ATTACHMENTS_ENABLED=true
ATTACHMENTS_BASE_DIR=
ATTACHMENTS_MAX_FILES=3
ATTACHMENTS_MAX_FILE_SIZE_MB=20
ATTACHMENTS_MAX_EXTRACTED_CHARACTERS_PER_FILE=30000
ATTACHMENTS_MAX_TOTAL_EXTRACTED_CHARACTERS=60000
ATTACHMENTS_ALLOWED_EXTENSIONS=.txt,.md,.csv,.pdf,.docx,.xlsx,.png,.jpg,.jpeg,.webp
ATTACHMENTS_INCLUDE_FILENAMES_IN_PROMPT=true

IMAGE_PROCESSING_MODE=metadata
OLLAMA_VISION_MODEL=llava:latest
OLLAMA_VISION_TIMEOUT_SECONDS=180
IMAGE_MAX_SIZE_MB=10
IMAGE_MAX_DIMENSION_PIXELS=8000
IMAGE_ANALYSIS_PROMPT=Beschreibe den relevanten Inhalt dieses Bildes präzise auf Deutsch. Wenn Text erkennbar ist, gib ihn sinngemäß wieder. Erfinde keine Details.
